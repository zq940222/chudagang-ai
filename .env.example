# Database (Prisma)
DATABASE_URL="postgresql://user:password@host:5432/chudagang?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/chudagang?schema=public"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth (v5 uses AUTH_SECRET; NEXTAUTH_SECRET is kept for compatibility)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Upstash Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# AI Configuration
AI_DEFAULT_PROVIDER="azure" # openai | azure | claude | qwen

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL_NAME="gpt-4o-mini"

# Azure OpenAI
AZURE_API_KEY=""
AZURE_RESOURCE_NAME=""
AZURE_DEPLOYMENT_NAME="gpt-4o"
AZURE_API_VERSION="2024-10-21"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Supabase (Storage / Admin)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
